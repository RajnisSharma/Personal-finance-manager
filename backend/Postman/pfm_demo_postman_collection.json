              },
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Emergency Fund\", \"target_amount\": 3000.00, \"current_amount\": 400.00, \"target_date\": \"2026-12-31\"}"
            },
            "url": {
              "raw": "{{base_url}}/goals/",
              "host": ["{{base_url}}"],
              "path": ["goals", "/"]
            }
          }
        },
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/summary/",
              "host": ["{{base_url}}"],
              "path": ["summary", "/"]
            }
          }
        }
      ]
    }
  ]
}