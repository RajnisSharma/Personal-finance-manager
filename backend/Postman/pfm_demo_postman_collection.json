{
  "info": {
    "name": "PFM Demo Collection",
    "description": "Demo collection for Personal Finance Manager API testing with admin, manager, and user roles",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "manager_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "manager_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "account_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "category_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"admin\", \"password\": \"TestPass123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"admin_token\", jsonData.access);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"manager_demo\", \"password\": \"ManagerDemo123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"manager_token\", jsonData.access);",
                  "pm.collectionVariables.set(\"manager_id\", jsonData.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"user_demo\", \"password\": \"UserDemo123!\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login/",
              "host": ["{{base_url}}"],
              "path": ["auth", "login", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"user_token\", jsonData.access);",
                  "pm.collectionVariables.set(\"user_id\", jsonData.user.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "User Management (Admin)",
      "item": [
        {
          "name": "Create Manager",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"manager_demo\", \"email\": \"manager_demo@test.com\", \"password\": \"ManagerDemo123!\", \"first_name\": \"Manager\", \"last_name\": \"Demo\", \"role\": \"manager\", \"is_active\": true, \"base_currency\": \"USD\"}"
            },
            "url": {
              "raw": "{{base_url}}/auth/management/users/",
              "host": ["{{base_url}}"],
              "path": ["auth", "management", "users", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"manager_id\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"username\": \"user_demo\", \"email\": \"user_demo@test.com\", \"password\": \"UserDemo123!\", \"first_name\": \"User\", \"last_name\": \"Demo\", \"role\": \"user\", \"is_active\": true, \"base_currency\": \"USD\", \"manager_ids\": [{{manager_id}}]}"
            },
            "url": {
              "raw": "{{base_url}}/auth/management/users/",
              "host": ["{{base_url}}"],
              "path": ["auth", "management", "users", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"user_id\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "List All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/management/users/",
              "host": ["{{base_url}}"],
              "path": ["auth", "management", "users", "/"]
            }
          }
        }
      ]
    },
    {
      "name": "User Management (Manager)",
      "item": [
        {
          "name": "List Assigned Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{manager_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/management/users/",
              "host": ["{{base_url}}"],
              "path": ["auth", "management", "users", "/"]
            }
          }
        },
        {
          "name": "Get User Report",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{manager_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/management/users/{{user_id}}/report/",
              "host": ["{{base_url}}"],
              "path": ["auth", "management", "users", "{{user_id}}", "report", "/"]
            }
          }
        }
      ]
    },
    {
      "name": "Finance Operations (User)",
      "item": [
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Demo Checking\", \"type\": \"checking\", \"balance\": 1200.00, \"currency\": \"USD\"}"
            },
            "url": {
              "raw": "{{base_url}}/accounts/",
              "host": ["{{base_url}}"],
              "path": ["accounts", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"account_id\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Groceries\", \"type\": \"expense\"}"
            },
            "url": {
              "raw": "{{base_url}}/categories/",
              "host": ["{{base_url}}"],
              "path": ["categories", "/"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"category_id\", jsonData.id);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create Transaction",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"account\": {{account_id}}, \"category\": {{category_id}}, \"date\": \"2026-04-03\", \"amount\": -150.00, \"description\": \"Grocery shopping\"}"
            },
            "url": {
              "raw": "{{base_url}}/transactions/",
              "host": ["{{base_url}}"],
              "path": ["transactions", "/"]
            }
          }
        },
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"name\": \"Food\", \"category\": {{category_id}}, \"limit\": 500.00, \"period\": \"month\"}"
            },
            "url": {
              "raw": "{{base_url}}/budgets/",
              "host": ["{{base_url}}"],
              "path": ["budgets", "/"]
            }
          }
        },
        {
          "name": "Create Goal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
